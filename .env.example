# Copia este fichero como .env y rellena los tokens reales.

# Airtable — usado por fetch-coaches.mjs para sincronizar teléfonos de coaches.
# Obtén tu token en: https://airtable.com/create/tokens
# Permisos necesarios: data.records:read  (base: Coaches)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Barca Academy Attendance API — usado por process.py y enrich-attendance.mjs
# para leer la asistencia de jugadores registrada por los coaches.
BARCA_ATTENDANCE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
